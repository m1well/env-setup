### cli dev tools ###

# curl
alias curl='curl -w "\n"'


# docker
alias doccomd="docker compose down"
alias doccomu="docker compose up"
alias doccomud="docker compose up -d"
alias doci="docker image ls"
alias docirm="docker image rm"
alias docps="docker ps -a"


# git
alias gitaa="git add ."
alias gitaacoa="git add . && git commit --amend"
alias gitbra="git rev-parse --abbrev-ref HEAD"
alias gitch="git checkout"
alias gitchbr="git_checkout_new_branch"
alias gitcoa="git commit --amend"
alias gitcoaner="git commit --amend --no-edit --reset-author"
alias gitcom="git commit"
alias gitconf="git config --list"
alias gitfa="git fetch --all"
alias gitll="git log -2 --graph --pretty=format:'%C(132)%h - %C(251)%s %C(45)(%ad) %C(33)<%cn>%Creset' --date=local"
alias gitpod="git_current_develop"
alias gitpom="git_current_main"
alias gitpot="git_current_test"
alias gitpsh="git_push"
alias gitrb="git rebase"
alias gitrba="git rebase --abort"
alias gitrbc="git rebase --continue"
alias gitrevert="git reset HEAD~1"
alias gitst="git status"


# gradle

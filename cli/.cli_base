### cli base ###

alias helloworld="echo \"Hello World!\""
alias home='cd "${HOME}"';
alias kkmm="cd .. && ls -alp"
alias mm="ls -alp"
alias mmm="ls -alprt"
alias k-="cd - >/dev/null"
alias kk="cd .."
alias kkk="cd .. && cd .."
alias kkkk="cd .. && cd .. && cd .."
alias cc="clear"
alias xx="exit"

alias octals='bash -c "printf \" -- %b\n\" \\\\1{3,7}{3,4,5,6}"'

alias chrome="open -a \"Google Chrome\" --new --args -incognito"

# grep given string recursively (add search-string and path)
alias greprec="grep -in --directories=recurse"

TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S")
export TIMESTAMP

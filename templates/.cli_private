### cli private ###
# here you can store private stuff which isn't tracked via git.
# export the m1well's toolsuite home like
# 'export M1WELL_TOOLSUITE_HOME="/Users/<your-user-home>/<path-to-toolsuite>"; '

ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/dotfiles/.vimrc" "${HOME}/.vimrc"
ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/nvim/init.lua" "${HOME}/.config/nvim/init.lua"
ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/terminal/m1well.plist" "${HOME}/Library/Application Support/iTerm2/DynamicProfiles/m1well.plist"
ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/terminal/m1well.zsh-theme" "${HOME}/.oh-my-zsh/themes/m1well.zsh-theme"

ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/claude-code/settings.json" "${HOME}/.claude/settings.json"
ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/claude-code/statusline.sh" "${HOME}/.claude/statusline.sh"
ln -sf "${M1WELL_TOOLSUITE_HOME}/env-setup/claude-code/CLAUDE.md" "${HOME}/.claude/CLAUDE.md"
rm -rf "${HOME}/.claude/skills" && ln -s "${M1WELL_TOOLSUITE_HOME}/env-setup/claude-code/skills" "${HOME}/.claude/skills"
rm -rf "${HOME}/.claude/hooks" && ln -s "${M1WELL_TOOLSUITE_HOME}/env-setup/claude-code/hooks" "${HOME}/.claude/hooks"
